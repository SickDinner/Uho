{
  "name": "uho-fate-of-grid",
  "version": "1.0.0",
  "description": "UHO: Fate of the Grid - A Finnish grid-based life simulation game",
  "main": "src/main.ts",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "dev:sim": "node node_modules/vite/bin/vite.js --host 0.0.0.0 --port 4173 --strictPort",
    "typecheck:sim": "node node_modules/typescript/bin/tsc --noEmit --target ES2022 --lib ES2022,DOM --moduleResolution bundler --allowImportingTsExtensions --skipLibCheck src/genius-life-app.ts src/main.ts",
    "build:sim": "node node_modules/vite/bin/vite.js build",
    "test:fast": "node node_modules/vitest/vitest.mjs run --passWithNoTests"
  },
  "keywords": [
    "game",
    "typescript",
    "canvas",
    "simulation",
    "ecs"
  ],
  "author": "Ville Peuho",
  "license": "MIT",
  "devDependencies": {
    "@types/howler": "^2.2.12",
    "@types/node": "^20.0.0",
    "@vitest/ui": "^1.0.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@tonejs/ui": "^0.1.5",
    "audio-buffer-utils": "^5.1.2",
    "howler": "^2.2.4",
    "tone": "^15.1.22"
  }
}
